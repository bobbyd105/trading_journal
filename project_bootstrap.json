        "Tags",
        "Screenshots"
      ]
    },
    {
      "phase": 3,
      "name": "Reviews and Psychology",
      "deliverables": [
        "Trade reviews",
        "Psychology scoring"
      ]
    },
    {
      "phase": 4,
      "name": "Analytics",
      "deliverables": [
        "Dashboard",
        "Metrics",
        "Grouping analytics"
      ]
    }
  ],
  "codex_task": {
    "instructions": [
      "Use the authoritative documentation as the project constitution.",
      "Build only V1-Lite.",
