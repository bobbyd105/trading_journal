{
  "project": {
    "name": "trading_journal",
    "description": "Local-first trading journal for Munch inspired by TradeZella.",
    "status": "implementation_ready",
    "source_of_truth": "sqlite"
  },
  "authoritative_documents": {
    "product_requirements": "Loaded and approved",
    "data_model": "Loaded and approved",
    "architecture": "Loaded and approved",
    "roadmap": "Loaded and approved"
  },
  "implementation_mode": "v1_lite",
  "implementation_rules": [
    "Use existing documentation as authoritative.",
    "Prefer simplicity over completeness.",
    "Optimize for first real-world usage.",
    "Do not implement TradeLocker import.",
    "Do not implement cloud sync.",
    "Do not implement AI features.",
    "Do not implement advanced review workflows.",
    "Do not implement execution-level trade entry UI.",
    "Do not implement daily journal.",
    "All analytics must derive from canonical trade records.",
    "Preserve user-entered values.",
    "Use local SQLite as source of truth."
  ],
  "tech_stack": {
    "frontend": "React + Vite",
    "backend": "Python",
    "database": "SQLite"
  },
  "v1_schema": {
    "tables": [
      "accounts",
      "instruments",
      "playbooks",
      "trades",
      "tags",
      "trade_tags",
      "attachments",
      "trade_attachments",
      "psychology_entries",
      "trade_reviews"
    ]
  },
  "trade_statuses": [
    "draft",
    "closed",
    "reviewed",
    "archived"
  ],
  "pages": [
    "Dashboard",
    "Trades",
    "Trade Detail",
    "Playbooks",
    "Settings"
  ],
  "trade_entry_fields": [
    "symbol",
    "direction",
    "entry_price",
    "exit_price",
    "quantity",
    "pnl",
    "risk",
    "playbook",
    "tags",
    "notes"
  ],
  "attachments": {
    "enabled": true,
    "supported_types": [
      "before_screenshot",
      "after_screenshot"
    ],
    "storage": "metadata_only"
  },
  "analytics": {
    "dashboard_metrics": [
      "net_pnl",
      "win_rate",
      "profit_factor",
      "average_r",
      "total_trades"
    ],
    "groupings": [
      "playbook",
      "symbol",
      "direction",
      "day_of_week"
    ]
  },
